// Prisma schema mirroring the existing Supabase/PostgreSQL database.
// This introspects the SAME database — no new migrations needed.
// Auth tables (auth.users) remain managed by Supabase Auth SDK.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────

enum user_role {
  guest
  pending
  alumni
  admin
  super_admin
}

enum approval_status {
  pending
  approved
  rejected
}

enum payment_status {
  pending
  success
  failed
  refunded
}

enum membership_type {
  lifetime
  annual
}

// ─── PROFILES ───────────────────────────────────────────────────────

model profiles {
  id             String   @id @db.Uuid
  full_name      String
  display_name   String?
  avatar_url     String?
  date_of_birth  DateTime? @db.Date
  gender         String?

  batch_year     Int
  course         String
  roll_number    String?

  email          String
  phone          String?
  alternate_phone String?

  current_city    String?
  current_state   String?
  current_country String?  @default("India")
  pincode         String?

  occupation     String?
  company        String?
  job_title      String?
  industry       String?
  linkedin_url   String?
  website_url    String?

  bio            String?
  achievements   String?

  hide_email     Boolean @default(false)
  hide_phone     Boolean @default(false)

  role             user_role       @default(pending)
  approval_status  approval_status @default(pending)
  approved_at      DateTime?       @db.Timestamptz(6)
  approved_by      String?         @db.Uuid
  rejection_reason String?

  membership_type       membership_type?
  membership_expires_at DateTime?  @db.Date
  is_paid_member        Boolean    @default(false)

  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6) @updatedAt
  last_seen_at DateTime? @db.Timestamptz(6)
  is_active    Boolean   @default(true)

  // Self-relation: who approved this profile
  approver          profiles?       @relation("ApprovedBy", fields: [approved_by], references: [id])
  approved_profiles profiles[]      @relation("ApprovedBy")

  // Relations
  announcements     announcements[]
  events_created    events[]
  event_rsvps       event_rsvps[]
  forum_threads     forum_threads[]
  forum_replies     forum_replies[]
  payments          payments[]
  audit_logs        audit_log[]
  forum_categories  forum_categories[]
  site_settings     site_settings[]

  @@index([role])
  @@index([approval_status])
  @@index([batch_year])
  @@index([is_active])
  @@index([email])
}

// ─── ANNOUNCEMENTS ──────────────────────────────────────────────────

model announcements {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  slug            String    @unique
  content         String
  cover_image_url String?
  author_id       String    @db.Uuid
  is_pinned       Boolean   @default(false)
  is_published    Boolean   @default(false)
  published_at    DateTime? @db.Timestamptz(6)
  scheduled_for   DateTime? @db.Timestamptz(6)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6) @updatedAt

  author profiles @relation(fields: [author_id], references: [id])

  @@index([is_published, published_at(sort: Desc)])
}

// ─── EVENTS ─────────────────────────────────────────────────────────

model events {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String
  slug                  String    @unique
  description           String?
  banner_image_url      String?
  event_type            String    @default("in_person")
  venue                 String?
  online_link           String?
  starts_at             DateTime  @db.Timestamptz(6)
  ends_at               DateTime? @db.Timestamptz(6)
  registration_deadline DateTime? @db.Timestamptz(6)
  max_attendees         Int?
  is_published          Boolean   @default(false)
  created_by            String    @db.Uuid
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @db.Timestamptz(6) @updatedAt

  creator profiles      @relation(fields: [created_by], references: [id])
  rsvps   event_rsvps[]

  @@index([starts_at])
}

model event_rsvps {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id      String   @db.Uuid
  alumni_id     String   @db.Uuid
  registered_at DateTime @default(now()) @db.Timestamptz(6)

  event  events   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  alumni profiles @relation(fields: [alumni_id], references: [id], onDelete: Cascade)

  @@unique([event_id, alumni_id])
  @@index([event_id])
}

// ─── FORUM ──────────────────────────────────────────────────────────

model forum_categories {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  description   String?
  slug          String   @unique
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_by    String?  @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  creator profiles?      @relation(fields: [created_by], references: [id])
  threads forum_threads[]
}

model forum_threads {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id   String    @db.Uuid
  author_id     String    @db.Uuid
  title         String
  content       String
  is_pinned     Boolean   @default(false)
  is_locked     Boolean   @default(false)
  reply_count   Int       @default(0)
  last_reply_at DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6) @updatedAt

  category forum_categories @relation(fields: [category_id], references: [id], onDelete: Cascade)
  author   profiles         @relation(fields: [author_id], references: [id])
  replies  forum_replies[]

  @@index([category_id])
}

model forum_replies {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id  String   @db.Uuid
  author_id  String   @db.Uuid
  content    String
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6) @updatedAt

  thread forum_threads @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  author profiles      @relation(fields: [author_id], references: [id])

  @@index([thread_id])
}

// ─── PAYMENTS ───────────────────────────────────────────────────────

model membership_plans {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("INR")
  membership_type membership_type
  duration_months Int?
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now()) @db.Timestamptz(6)

  payments payments[]
}

model payments {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alumni_id           String         @db.Uuid
  plan_id             String?        @db.Uuid
  txnid               String         @unique
  easebuzz_payment_id String?
  amount              Decimal        @db.Decimal(10, 2)
  currency            String         @default("INR")
  status              payment_status @default(pending)
  payment_mode        String?
  bank_ref_num        String?
  gateway_response    Json?
  receipt_url         String?
  receipt_sent_at     DateTime?      @db.Timestamptz(6)
  created_at          DateTime       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime       @default(now()) @db.Timestamptz(6) @updatedAt

  alumni profiles         @relation(fields: [alumni_id], references: [id])
  plan   membership_plans? @relation(fields: [plan_id], references: [id])

  @@index([alumni_id])
  @@index([status])
}

// ─── AUDIT LOG ──────────────────────────────────────────────────────

model audit_log {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id    String?  @db.Uuid
  action      String
  target_type String?
  target_id   String?  @db.Uuid
  metadata    Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  actor profiles? @relation(fields: [actor_id], references: [id])
}

// ─── SITE SETTINGS ──────────────────────────────────────────────────

model site_settings {
  key        String   @id
  value      Json?
  updated_by String?  @db.Uuid
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  updater profiles? @relation(fields: [updated_by], references: [id])
}
